# === Independent AI (independentai.space) ===

# --- AI provider API keys ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# --- Database (Neon free tier — postgres) ---
# Format: postgresql://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=postgresql://user:pass@host.neon.tech/independentai?sslmode=require

# --- Redis (Upstash free tier — BullMQ uyumlu, TLS) ---
# Upstash dashboard'undan kopyala (rediss:// ile başlar)
REDIS_URL=rediss://default:pass@xxx.upstash.io:6379

# --- App config ---
JWT_SECRET=change-me-please-make-it-at-least-32-chars
WEB_PORT=3200
API_PORT=4002
NEXT_PUBLIC_API_URL=http://localhost:4002
NEXT_PUBLIC_SITE_URL=https://independentai.space

# --- Launch promo ---
FREE_TRIAL_MONTHS=6
LAUNCH_DATE=2026-05-22

# --- Cron (worker) ---
DAILY_RUN_CRON=0 2 * * *
