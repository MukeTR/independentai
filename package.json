{
  "name": "independentai",
  "version": "0.1.0",
  "private": true,
  "description": "Independent AI — şirketlerin ChatGPT, Claude, Gemini gibi yapay zekalarda kendi markalarının nasıl konumlandığını izlediği bağımsız görünürlük platformu (independentai.space)",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm --filter @independentai/db generate && turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @independentai/db generate",
    "db:push": "pnpm --filter @independentai/db push",
    "db:migrate": "pnpm --filter @independentai/db migrate",
    "db:migrate:deploy": "pnpm --filter @independentai/db migrate:deploy",
    "db:seed": "pnpm --filter @independentai/db seed",
    "db:studio": "pnpm --filter @independentai/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2",
    "@types/node": "^22.10.2"
  },
  "engines": {
    "node": "22.x",
    "pnpm": ">=9.0.0"
  },
  "prisma": {
    "schema": "packages/db/prisma/schema.prisma"
  }
}
